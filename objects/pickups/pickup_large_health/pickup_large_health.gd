extends PickupBody2D

# ------------------------------------------------------------------------------
# Constants
# ------------------------------------------------------------------------------
const HEALTH_VALUE : int = 15

# ------------------------------------------------------------------------------
# Override Methods
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Handler Methods
# ------------------------------------------------------------------------------
func _on_detected(hitbox : HitBox) -> void:
	if sound_sheet != null:
		sound_sheet.play(AUDIO)
	hitbox.heal(HEALTH_VALUE)
	queue_free.call_deferred()
