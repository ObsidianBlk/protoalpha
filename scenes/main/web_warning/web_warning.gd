extends PanelContainer

# ------------------------------------------------------------------------------
# Constants
# ------------------------------------------------------------------------------
const OS_WEB_NAME : String = "Web"

# ------------------------------------------------------------------------------
# Override Methods
# ------------------------------------------------------------------------------
func _ready() -> void:
	visible = OS.get_name() == OS_WEB_NAME
	if not visible:
		queue_free()

# ------------------------------------------------------------------------------
# Handler Methods
# ------------------------------------------------------------------------------

func _on_btn_clicker_pressed() -> void:
	visible = false
	queue_free.call_deferred()
